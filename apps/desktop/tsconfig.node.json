{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "types": ["node"],
    // vite.config.ts imports the plain-JS dev-constants module (it must stay
    // .mjs — scripts/dev.mjs runs under plain node, so a .ts file won't do).
    "allowJs": true
  },
  "include": ["src/main/**/*", "src/preload/**/*", "vite.config.ts", "scripts/dev-constants.mjs"]
}
