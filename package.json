{
  "name": "volli-code",
  "version": "0.0.1",
  "description": "Volli Code — kanban planning + terminal-agent execution (Electron rewrite)",
  "private": true,
  "type": "module",
  "engines": { "node": "^24.13.0" },
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "vp run --filter @volli/desktop dev",
    "build": "vp run --filter @volli/desktop build",
    "start": "vp run --filter @volli/desktop start",
    "ensure:electron": "vp run --filter @volli/desktop ensure:electron",
    "typecheck": "vp run -r typecheck",
    "test": "vp run -r test",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "check": "vp check"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  }
}
