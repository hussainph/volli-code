{
  "name": "volli-electron",
  "version": "0.0.1",
  "description": "Electron spike: kanban board + embedded terminal",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently \"npm run watch\" \"wait-on tcp:5173 && electron .\"",
    "watch": "vite",
    "build": "vite build && tsc src/main.ts --outDir dist",
    "start": "electron ."
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "electron": "^latest",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "xterm": "^5.5.0",
    "xterm-addon-fit": "^0.10.0",
    "node-pty": "^0.10.1"
  }
}
