{
  "name": "volli-code",
  "version": "0.0.1",
  "private": true,
  "description": "Volli Code — kanban planning + terminal-agent execution (Electron rewrite)",
  "type": "module",
  "scripts": {
    "prepare": "vp config --no-agent",
    "dev": "vp run --filter @volli/desktop dev",
    "build": "vp run --filter @volli/desktop build",
    "start": "vp run --filter @volli/desktop start",
    "ensure:electron": "vp run --filter @volli/desktop ensure:electron",
    "typecheck": "tsc --noEmit -p tsconfig.json && vp run -r typecheck",
    "test": "vp run -r test",
    "test:coverage": "vp run -r test:coverage",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "check": "vp check"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": "^24.13.0"
  },
  "packageManager": "pnpm@11.10.0"
}
